# --- Build output & dependencies ---
node_modules/
dist/
*.tsbuildinfo

# --- InterComm runtime data (created by master in project dir) ---
.intercomm/
.intercomm-aimfp/

# Per-worker git worktrees (created by scripts/spawn-workers.sh --worktrees)
.intercomm-worktrees/

# AIMFP project state (.aimfp-project/) is intentionally TRACKED — AIMFP's git
# model commits project.db / user_preferences.db so clones and per-worker worktrees
# carry the project state. InterComm's own runtime DBs are already excluded by the
# .intercomm-aimfp/ and .intercomm-worktrees/ directory ignores above, so NO blanket
# *.db rule is used here (it would swallow the AIMFP DBs).

# --- Local-only reference material (not tracked, not part of the build) ---
# Planning/handoff docs and the ctx reference repo are kept locally only.
docs/
ctx/

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS cruft ---
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini
